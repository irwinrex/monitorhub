logging {
  level  = coalesce(sys.env("ALLOY_LOG_LEVEL"), "info")
  format = "json"
}

discovery.docker "containers" {
  host             = "unix:///var/run/docker.sock"
  refresh_interval = "10s"
}

discovery.relabel "app_containers" {
  targets = discovery.docker.containers.targets

  // Filter by docker compose project name
  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
    regex         = sys.env("ALLOY_DOCKER_PROJECT")
    action        = "keep"
  }

  // Keep only whitelisted service names (pipe-separated regex)
  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    regex         = sys.env("ALLOY_SERVICE_NAMES")
    action        = "keep"
  }

  // Promote service name as a label
  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service"
    action        = "replace"
  }

  // Set environment label from ALLOY_ENVIRONMENT
  rule {
    target_label  = "environment"
    replacement   = sys.env("ALLOY_ENVIRONMENT")
    action        = "replace"
  }
}

loki.source.docker "containers" {
  host          = "unix:///var/run/docker.sock"
  targets       = discovery.relabel.app_containers.output
  relabel_rules = discovery.relabel.app_containers.rules

  forward_to = [loki.process.logs.receiver]
}

loki.process "logs" {
  stage.labels {
    values = {
      service   = "service",
      container = "container_name",
      stream    = "stream",
    }
  }

  stage.match {
    selector = `{service=""}`
    action   = "drop"
  }

  stage.timestamp {
    source            = "time"
    format            = "RFC3339"
    action_on_failure = "skip"
  }

  forward_to = [loki.write.loki.receiver]
}

loki.write "loki" {
  endpoint {
    url = sys.env("ALLOY_LOKI_URL")

    basic_auth {
      username = sys.env("ALLOY_AUTH_USERNAME")
      password = sys.env("ALLOY_AUTH_PASSWORD")
    }

    tls_config {
      insecure_skip_verify = false
    }
  }
}
